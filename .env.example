NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXTAUTH_URL=http://localhost:3000

# Optional legacy database (not required for current user history flow)
DATABASE_URL=

# Giscus
NEXT_PUBLIC_GISCUS_REPO=owner/repo
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID=
# Legacy compatibility only. Blog comments are pinned to specific term: /zh/blog/${slug}
NEXT_PUBLIC_GISCUS_MAPPING=pathname

# Umami
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://umami.example.com/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
UMAMI_API_TOKEN=
UMAMI_API_BASE_URL=
SITE_START_DATE=2026-03-02

# Admin Auth (GitHub OAuth)
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Strict admin policy: must only be 2982136527
ADMIN_GITHUB_ALLOWLIST=2982136527

# GitHub publishing
# Content repository (private)
CONTENT_GITHUB_OWNER=
CONTENT_GITHUB_REPO=
CONTENT_GITHUB_BASE_BRANCH=main
CONTENT_GITHUB_WRITE_TOKEN=
CONTENT_GITHUB_READ_TOKEN=

# Public repository (docs mirror target)
PUBLIC_GITHUB_OWNER=
PUBLIC_GITHUB_REPO=
PUBLIC_GITHUB_BASE_BRANCH=main
PUBLIC_GITHUB_WRITE_TOKEN=
ADMIN_AUTO_MERGE=true
CRON_SECRET=
VERCEL_DEPLOY_HOOK_URL=
TUTORIAL_SYNC_ENABLED=true
PRIVACY_BLOCKLIST=

# Daily automations:
# - GitHub hot daily: 08:00 (+09:10 fallback), tags: ai-auto/github-hot
# - AI paper daily: 12:30, tags: ai-paper/paper-daily

# Repo cards for normal posts reuse existing Content GitHub + Deploy Hook env vars.

# AI writing enhancement
AI_ENABLE=true
AI_PROVIDER_CHAIN=gemini,openai,deepseek,qwen
AI_TIMEOUT_MS=60000
AI_RETRY_COUNT=1

# Gemini
AI_GEMINI_API_KEY=
AI_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AI_GEMINI_MODEL=gemini-3.1-pro-preview

# OpenAI compatible (custom proxy or OpenAI)
AI_OPENAI_API_KEY=
AI_OPENAI_BASE_URL=https://api.openai.com/v1
AI_OPENAI_MODEL=gpt-4o-mini

# DeepSeek
AI_DEEPSEEK_API_KEY=
AI_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
AI_DEEPSEEK_MODEL=deepseek-chat

# Qwen
AI_QWEN_API_KEY=
AI_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_QWEN_MODEL=qwen-plus
