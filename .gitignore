# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.tmp-*.png

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# private content sync (for public code repository workflow)
content/posts/**
content/system/**
public/images/uploads/**
!content/posts/.gitkeep
!content/system/.gitkeep
!public/images/uploads/.gitkeep

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
